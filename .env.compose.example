# Copy this file to .env.compose to override defaults locally.
COMPOSE_PROJECT_NAME=archive-stack
# Optional: pin ./test runs to one Compose project instead of per-invocation isolation.
# TEST_COMPOSE_PROJECT_NAME=archive-stack-test

ARC_API_PORT=8000
ARC_WEBDAV_PORT=8080

ARC_OBJECT_STORE=s3
ARC_S3_ENDPOINT_URL=http://garage:3900
ARC_S3_REGION=garage
ARC_S3_BUCKET=riverhog
ARC_S3_ACCESS_KEY_ID=GK000000000000000000000001
ARC_S3_SECRET_ACCESS_KEY=1111111111111111111111111111111111111111111111111111111111111111
ARC_S3_FORCE_PATH_STYLE=true
ARC_GLACIER_ENDPOINT_URL=http://garage:3900
ARC_GLACIER_REGION=garage
ARC_GLACIER_BUCKET=riverhog-archive
ARC_GLACIER_ACCESS_KEY_ID=GK000000000000000000000002
ARC_GLACIER_SECRET_ACCESS_KEY=2222222222222222222222222222222222222222222222222222222222222222
ARC_GLACIER_FORCE_PATH_STYLE=true
ARC_GLACIER_PREFIX=glacier
ARC_GLACIER_BACKEND=s3
ARC_GLACIER_STORAGE_CLASS=DEEP_ARCHIVE
ARC_GLACIER_UPLOAD_RETRY_LIMIT=3
ARC_GLACIER_UPLOAD_RETRY_DELAY=5m
ARC_GLACIER_UPLOAD_SWEEP_INTERVAL=30s
ARC_GLACIER_FAILURE_WEBHOOK_URL=
ARC_GLACIER_RECOVERY_SWEEP_INTERVAL=30s
ARC_GLACIER_RECOVERY_RESTORE_LATENCY=48h
ARC_GLACIER_RECOVERY_READY_TTL=24h
ARC_OTS_STAMP_COMMAND=ots
ARC_OTS_VERIFY_COMMAND=ots
ARC_RECOVERY_PAYLOAD_COMMAND=age
ARC_RECOVERY_PAYLOAD_REQUIRE_EXPLICIT_PASSPHRASE=false
ARC_RECOVERY_PAYLOAD_PASSPHRASE=archive-stack-dev-recovery-passphrase
ARC_RECOVERY_PAYLOAD_WORK_FACTOR=18
ARC_RECOVERY_PAYLOAD_MAX_WORK_FACTOR=30
ARC_TUSD_BASE_URL=http://tusd:1080/files
ARC_TUSD_HOOK_SECRET=dev-tusd-hook-secret
ARC_WEBDAV_ENABLED=true
ARC_WEBDAV_ADDR=0.0.0.0:8080

ARC_DB_PATH=/app/.compose/state.sqlite3
ARC_PUBLIC_BASE_URL=http://app:8000

ARC_TEST_EXTERNAL_APP_BASE_URL=http://app:8000
ARC_TEST_EXTERNAL_APP_DB_PATH=/app/.compose/state.sqlite3
ARC_TEST_EXTERNAL_WEBDAV_BASE_URL=http://webdav:8080

INCOMPLETE_UPLOAD_TTL=24h
UPLOAD_EXPIRY_SWEEP_INTERVAL=30s
