#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="${TEST_IMAGE_NAME:-archive-stack:test}"

if [[ $# -eq 0 ]]; then
  MODE="canonical"
elif [[ "$1" == "acceptance" ]]; then
  MODE="pytest"
  shift
  set -- -q -m acceptance tests/acceptance "$@"
else
  MODE="pytest"
fi

TTY_ARGS=()
if [[ -t 0 && -t 1 ]]; then
  TTY_ARGS=(-it)
fi

docker build \
  --file "${ROOT_DIR}/Dockerfile.test" \
  --tag "${IMAGE_NAME}" \
  "${ROOT_DIR}"

if [[ "${MODE}" == "canonical" ]]; then
  exec docker run \
    --rm \
    --init \
    "${TTY_ARGS[@]}" \
    --entrypoint bash \
    "${IMAGE_NAME}" \
    -lc "python -m pytest -q -m acceptance tests/acceptance && python -m pytest -q tests/integration tests/unit"
fi

exec docker run \
  --rm \
  --init \
  "${TTY_ARGS[@]}" \
  "${IMAGE_NAME}" \
  "$@"
