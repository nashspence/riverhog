#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="${TEST_IMAGE_NAME:-archive-stack:test}"

usage() {
  cat <<'EOF'
Usage:
  ./test
  ./test acceptance [pytest args...]
  ./test acceptance-profile [pytest args...]
  ./test spec [pytest args...]
  ./test unit [pytest args...]
  ./test fast [pytest args...]
  ./test [pytest args...]

Modes:
  acceptance  Run the production-backed BDD acceptance lane.
  acceptance-profile  Run the production-backed acceptance lane with profiling output.
  spec        Run the fixture-backed BDD spec harness lane.
  unit        Run the unit test lane.
  fast        Run the non-production lanes together (integration + unit).
  no args     Run the canonical split test flow inside the test container.
EOF
}

MODE="pytest"
DOCKER_ENV_ARGS=()

if [[ $# -eq 0 ]]; then
  MODE="canonical"
else
  case "$1" in
    acceptance)
      shift
      set -- -q -m acceptance tests/acceptance "$@"
      ;;
    acceptance-profile)
      shift
      DOCKER_ENV_ARGS=(-e ARC_TEST_PROFILE=1)
      set -- -q --durations=0 --durations-min=0.5 -m acceptance tests/acceptance "$@"
      ;;
    spec)
      shift
      set -- -q tests/integration "$@"
      ;;
    unit)
      shift
      set -- -q tests/unit "$@"
      ;;
    fast)
      shift
      set -- -q tests/integration tests/unit "$@"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

TTY_ARGS=()
if [[ -t 0 && -t 1 ]]; then
  TTY_ARGS=(-it)
fi

docker build \
  --file "${ROOT_DIR}/Dockerfile.test" \
  --tag "${IMAGE_NAME}" \
  "${ROOT_DIR}"

if [[ "${MODE}" == "canonical" ]]; then
  read -r -d '' CANONICAL_SCRIPT <<'EOF' || true
set -euo pipefail

run_phase() {
  local label="$1"
  shift
  local started_at
  started_at="$(date +%s)"

  printf '\n==> %s\n' "${label}"
  "$@"

  local finished_at
  finished_at="$(date +%s)"
  printf '==> %s finished in %ss\n' "${label}" "$((finished_at - started_at))"
}

run_phase "acceptance" python -m pytest -q -m acceptance tests/acceptance
run_phase "integration + unit" python -m pytest -q tests/integration tests/unit
EOF

  exec docker run \
    --rm \
    --init \
    "${TTY_ARGS[@]}" \
    --entrypoint bash \
    "${IMAGE_NAME}" \
    -lc "${CANONICAL_SCRIPT}"
fi

exec docker run \
  --rm \
  --init \
  "${TTY_ARGS[@]}" \
  "${DOCKER_ENV_ARGS[@]}" \
  "${IMAGE_NAME}" \
  "$@"
