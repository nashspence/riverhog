#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${ROOT_DIR}/compose.yml"
DEFAULT_ENV_FILE="${ROOT_DIR}/.env.compose.example"
LOCAL_ENV_FILE="${ROOT_DIR}/.env.compose"
PROD_HARNESS_ENV_FILE="${ROOT_DIR}/tests/harness/prod-harness.env"

if [[ -f "${LOCAL_ENV_FILE}" ]]; then
  COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-${LOCAL_ENV_FILE}}"
else
  COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-${DEFAULT_ENV_FILE}}"
fi

compose() {
  docker compose \
    --file "${COMPOSE_FILE}" \
    --env-file "${COMPOSE_ENV_FILE}" \
    "$@"
}

compose_env_value() {
  local name="$1"
  local default="${2-}"
  if [[ -n "${!name-}" ]]; then
    printf '%s' "${!name}"
    return
  fi
  local line
  line="$(grep -E "^${name}=" "${COMPOSE_ENV_FILE}" | tail -n 1 || true)"
  if [[ -n "${line}" ]]; then
    printf '%s' "${line#*=}"
    return
  fi
  printf '%s' "${default}"
}

load_env_defaults() {
  local env_file="$1"
  local line=""
  local name=""
  local value=""

  if [[ ! -f "${env_file}" ]]; then
    printf 'missing env file: %s\n' "${env_file}" >&2
    exit 1
  fi

  while IFS= read -r line || [[ -n "${line}" ]]; do
    if [[ -z "${line}" || "${line}" == \#* ]]; then
      continue
    fi

    name="${line%%=*}"
    value="${line#*=}"
    if [[ -z "${name}" || "${name}" == "${line}" ]]; then
      printf 'invalid env assignment in %s: %s\n' "${env_file}" "${line}" >&2
      exit 1
    fi

    if [[ -z "${!name-}" ]]; then
      export "${name}=${value}"
    fi
  done < "${env_file}"
}

sanitize_compose_project_component() {
  local value="${1:-}"
  value="$(printf '%s' "${value}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-')"
  value="${value#-}"
  value="${value%-}"
  if [[ -z "${value}" ]]; then
    printf 'user'
    return
  fi
  printf '%s' "${value}"
}

default_test_compose_project_name() {
  local user_component
  user_component="$(sanitize_compose_project_component "${USER:-}")"
  printf 'archive-stack-test-%s-%s' "${user_component}" "$$"
}

TEST_COMPOSE_PROJECT_NAME_VALUE="${TEST_COMPOSE_PROJECT_NAME:-}"
if [[ -z "${TEST_COMPOSE_PROJECT_NAME_VALUE}" ]]; then
  TEST_COMPOSE_PROJECT_NAME_VALUE="$(compose_env_value TEST_COMPOSE_PROJECT_NAME)"
fi

if [[ -n "${TEST_COMPOSE_PROJECT_NAME_VALUE}" ]]; then
  export COMPOSE_PROJECT_NAME="${TEST_COMPOSE_PROJECT_NAME_VALUE}"
else
  export COMPOSE_PROJECT_NAME="$(default_test_compose_project_name)"
fi

usage() {
  cat <<'EOF'
Usage:
  ./test
  ./test lint [mypy-baseline args...]
  ./test prod [pytest args...]
  ./test prod-profile [pytest args...]
  ./test spec [pytest args...]
  ./test unit [pytest args...]
  ./test fast [pytest args...]
  ./test [pytest args...]

Modes:
  lint        Run the canonical lint flow (ruff + baseline-backed mypy).
  prod        Run the production-backed BDD harness lane.
  prod-profile  Run the production-backed harness lane with profiling output.
  spec        Run the fixture-backed BDD spec harness lane.
  unit        Run the unit test lane.
  fast        Run the non-production lanes together (spec + unit).
  no args     Run the canonical split test flow inside the test container.

Compose env:
  Defaults to ./.env.compose if present, otherwise ./.env.compose.example.
  Prod-backed lanes also layer tests/harness/prod-harness.env for short recovery timing values.
  Test runs use an isolated compose project by default.
  Set TEST_COMPOSE_PROJECT_NAME to reuse a specific project name.
EOF
}

MODE="pytest"
COMPOSE_RUN_ENV_ARGS=()
LINT_ARGS=()
REQUIRES_SIDECARS=0

PROGRESS_CHECK_SECONDS="${PROGRESS_CHECK_SECONDS:-1}"
PROGRESS_REPORT_SECONDS="${PROGRESS_REPORT_SECONDS:-300}"

cleanup() {
  if [[ "${REQUIRES_SIDECARS}" == "1" ]]; then
    compose down --volumes --remove-orphans >/dev/null 2>&1 || true
  else
    compose down --remove-orphans >/dev/null 2>&1 || true
  fi
}

trap cleanup EXIT

if [[ $# -eq 0 ]]; then
  MODE="canonical"
  REQUIRES_SIDECARS=1
else
  case "$1" in
    lint)
      shift
      MODE="lint"
      LINT_ARGS=("$@")
      set --
      ;;
    prod)
      shift
      REQUIRES_SIDECARS=1
      set -- -q -m acceptance tests/harness/test_prod_harness.py "$@"
      ;;
    prod-profile)
      shift
      REQUIRES_SIDECARS=1
      COMPOSE_RUN_ENV_ARGS=(-e ARC_TEST_PROFILE=1)
      set -- -q --durations=0 --durations-min=0.5 -m acceptance tests/harness/test_prod_harness.py "$@"
      ;;
    spec)
      shift
      set -- -q tests/harness/test_spec_harness.py "$@"
      ;;
    unit)
      shift
      set -- -q tests/unit "$@"
      ;;
    fast)
      shift
      set -- -q tests/harness/test_spec_harness.py tests/unit "$@"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

COMPOSE_RUN_TTY_ARGS=()
if [[ ! -t 0 || ! -t 1 ]]; then
  COMPOSE_RUN_TTY_ARGS=(-T)
fi

compose build test

run_with_progress() {
  local label="$1"
  shift

  "$@" &
  local pid="$!"
  local started_at
  local last_report_at
  local now

  started_at="$(date +%s)"
  last_report_at="${started_at}"

  while kill -0 "${pid}" >/dev/null 2>&1; do
    sleep "${PROGRESS_CHECK_SECONDS}"

    if ! kill -0 "${pid}" >/dev/null 2>&1; then
      break
    fi

    now="$(date +%s)"
    if (( now - last_report_at >= PROGRESS_REPORT_SECONDS )); then
      printf '... %s still running after %ss\n' "${label}" "$((now - started_at))"
      last_report_at="${now}"
    fi
  done

  wait "${pid}"
}

garage_exec() {
  compose exec -T garage /garage -c /etc/garage.toml "$@"
}

bootstrap_garage() {
  local garage_node=""
  local garage_node_id=""
  local access_key_id
  local secret_access_key
  local bucket
  local glacier_access_key_id
  local glacier_secret_access_key
  local glacier_bucket
  access_key_id="$(compose_env_value ARC_S3_ACCESS_KEY_ID GK000000000000000000000001)"
  secret_access_key="$(compose_env_value ARC_S3_SECRET_ACCESS_KEY 1111111111111111111111111111111111111111111111111111111111111111)"
  bucket="$(compose_env_value ARC_S3_BUCKET riverhog)"
  glacier_access_key_id="$(compose_env_value ARC_GLACIER_ACCESS_KEY_ID "${access_key_id}")"
  glacier_secret_access_key="$(
    compose_env_value ARC_GLACIER_SECRET_ACCESS_KEY "${secret_access_key}"
  )"
  glacier_bucket="$(compose_env_value ARC_GLACIER_BUCKET "${bucket}")"

  run_with_progress "garage startup" compose up --detach garage

  for _ in $(seq 1 60); do
    garage_node="$(garage_exec node id 2>/dev/null | tail -n 1 || true)"
    if [[ "${garage_node}" == *@* ]] && garage_exec -h "${garage_node}" status >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done

  if [[ "${garage_node}" != *@* ]]; then
    printf 'garage bootstrap failed: could not resolve the running node id\n' >&2
    exit 1
  fi

  garage_node_id="${garage_node%@*}"
  run_with_progress \
    "garage layout assign" \
    garage_exec -h "${garage_node}" layout assign -z local -c 1GB "${garage_node_id}"
  run_with_progress \
    "garage layout apply" \
    garage_exec -h "${garage_node}" layout apply --version 1
  run_with_progress \
    "garage key import" \
    garage_exec -h "${garage_node}" key import --yes -n "${access_key_id}" "${access_key_id}" "${secret_access_key}"
  if [[ "${glacier_access_key_id}" != "${access_key_id}" || "${glacier_secret_access_key}" != "${secret_access_key}" ]]; then
    run_with_progress \
      "garage glacier key import" \
      garage_exec -h "${garage_node}" key import --yes -n "${glacier_access_key_id}" "${glacier_access_key_id}" "${glacier_secret_access_key}"
  fi
  run_with_progress \
    "garage bucket create" \
    garage_exec -h "${garage_node}" bucket create "${bucket}"
  if [[ "${glacier_bucket}" != "${bucket}" ]]; then
    run_with_progress \
      "garage glacier bucket create" \
      garage_exec -h "${garage_node}" bucket create "${glacier_bucket}"
  fi
  run_with_progress \
    "garage bucket allow" \
    garage_exec -h "${garage_node}" bucket allow --read --write --owner "${bucket}" --key "${access_key_id}"
  if [[ "${glacier_access_key_id}" != "${access_key_id}" || "${glacier_bucket}" != "${bucket}" ]]; then
    run_with_progress \
      "garage glacier bucket allow" \
      garage_exec -h "${garage_node}" bucket allow --read --write --owner "${glacier_bucket}" --key "${glacier_access_key_id}"
  fi
  run_with_progress \
    "garage lifecycle configure" \
    compose run --rm --entrypoint python "${COMPOSE_RUN_TTY_ARGS[@]}" test tests/harness/configure_garage.py
}

if [[ "${REQUIRES_SIDECARS}" == "1" ]]; then
  export ARC_ENABLE_TEST_CONTROL="${ARC_ENABLE_TEST_CONTROL:-1}"
  export ARC_TEST_WEBHOOK_CAPTURE_PATH="${ARC_TEST_WEBHOOK_CAPTURE_PATH:-/app/.compose/webhook-captures.jsonl}"
  export UPLOAD_EXPIRY_SWEEP_INTERVAL="${UPLOAD_EXPIRY_SWEEP_INTERVAL:-1s}"
  export ARC_GLACIER_UPLOAD_SWEEP_INTERVAL="${ARC_GLACIER_UPLOAD_SWEEP_INTERVAL:-1s}"
  export ARC_GLACIER_FAILURE_WEBHOOK_URL="${ARC_GLACIER_FAILURE_WEBHOOK_URL:-http://app:8000/_test/webhooks}"
  load_env_defaults "${PROD_HARNESS_ENV_FILE}"
  export ARC_GLACIER_RECOVERY_WEBHOOK_URL="${ARC_GLACIER_RECOVERY_WEBHOOK_URL:-http://app:8000/_test/webhooks}"
  compose build app
  compose down --volumes --remove-orphans >/dev/null 2>&1 || true
  bootstrap_garage
  run_with_progress "sidecar startup" compose up --detach webdav tusd
  run_with_progress "app startup" compose up --detach --wait app
fi

run_test_container() {
  compose run \
    --rm \
    "${COMPOSE_RUN_TTY_ARGS[@]}" \
    -e ARC_TEST_CANONICAL_ENTRYPOINT=1 \
    "${COMPOSE_RUN_ENV_ARGS[@]}" \
    test \
    "$@"
}

run_ruff_container() {
  compose run \
    --rm \
    "${COMPOSE_RUN_TTY_ARGS[@]}" \
    --entrypoint ruff \
    "${COMPOSE_RUN_ENV_ARGS[@]}" \
    test \
    check \
    .
}

run_mypy_baseline_container() {
  compose run \
    --rm \
    "${COMPOSE_RUN_TTY_ARGS[@]}" \
    --entrypoint python \
    "${COMPOSE_RUN_ENV_ARGS[@]}" \
    test \
    tests/harness/check_mypy_baseline.py \
    "$@"
}

run_lint() {
  local baseline_args=("$@")
  run_with_progress "ruff" run_ruff_container
  run_with_progress \
    "mypy baseline" \
    run_mypy_baseline_container "${baseline_args[@]}"
}

if [[ "${MODE}" == "canonical" ]]; then
  run_phase() {
    local label="$1"
    shift
    local started_at
    started_at="$(date +%s)"

    printf '\n==> %s\n' "${label}"
    run_with_progress "${label}" "$@"

    local finished_at
    finished_at="$(date +%s)"
    printf '==> %s finished in %ss\n' "${label}" "$((finished_at - started_at))"
  }

  run_phase "lint" run_lint
  run_phase "unit" run_test_container -q tests/unit
  run_phase "spec" run_test_container -q tests/harness/test_spec_harness.py
  run_phase "prod" run_test_container -q -m acceptance tests/harness/test_prod_harness.py
  exit 0
fi

if [[ "${MODE}" == "lint" ]]; then
  run_lint "${LINT_ARGS[@]}"
  exit 0
fi

run_with_progress "pytest" run_test_container "$@"
