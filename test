#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${ROOT_DIR}/compose.yml"
DEFAULT_ENV_FILE="${ROOT_DIR}/.env.compose.example"
LOCAL_ENV_FILE="${ROOT_DIR}/.env.compose"

if [[ -f "${LOCAL_ENV_FILE}" ]]; then
  COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-${LOCAL_ENV_FILE}}"
else
  COMPOSE_ENV_FILE="${COMPOSE_ENV_FILE:-${DEFAULT_ENV_FILE}}"
fi

export COMPOSE_PROJECT_NAME="${TEST_COMPOSE_PROJECT_NAME:-archive-stack-test}"

compose() {
  docker compose \
    --file "${COMPOSE_FILE}" \
    --env-file "${COMPOSE_ENV_FILE}" \
    "$@"
}

usage() {
  cat <<'EOF'
Usage:
  ./test
  ./test acceptance [pytest args...]
  ./test acceptance-profile [pytest args...]
  ./test spec [pytest args...]
  ./test unit [pytest args...]
  ./test fast [pytest args...]
  ./test [pytest args...]

Modes:
  acceptance  Run the production-backed BDD acceptance lane.
  acceptance-profile  Run the production-backed acceptance lane with profiling output.
  spec        Run the fixture-backed BDD spec harness lane.
  unit        Run the unit test lane.
  fast        Run the non-production lanes together (integration + unit).
  no args     Run the canonical split test flow inside the test container.

Compose env:
  Defaults to ./.env.compose if present, otherwise ./.env.compose.example.
EOF
}

MODE="pytest"
COMPOSE_RUN_ENV_ARGS=()
REQUIRES_SIDECARS=0
PROGRESS_POLL_SECONDS=60

cleanup() {
  if [[ "${REQUIRES_SIDECARS}" == "1" ]]; then
    compose down --volumes --remove-orphans >/dev/null 2>&1 || true
  fi
}

trap cleanup EXIT

if [[ $# -eq 0 ]]; then
  MODE="canonical"
  REQUIRES_SIDECARS=1
else
  case "$1" in
    acceptance)
      shift
      REQUIRES_SIDECARS=1
      set -- -q -m acceptance tests/acceptance "$@"
      ;;
    acceptance-profile)
      shift
      REQUIRES_SIDECARS=1
      COMPOSE_RUN_ENV_ARGS=(-e ARC_TEST_PROFILE=1)
      set -- -q --durations=0 --durations-min=0.5 -m acceptance tests/acceptance "$@"
      ;;
    spec)
      shift
      set -- -q tests/integration "$@"
      ;;
    unit)
      shift
      set -- -q tests/unit "$@"
      ;;
    fast)
      shift
      set -- -q tests/integration tests/unit "$@"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

COMPOSE_RUN_TTY_ARGS=()
if [[ ! -t 0 || ! -t 1 ]]; then
  COMPOSE_RUN_TTY_ARGS=(-T)
fi

compose build test

run_with_progress() {
  local label="$1"
  shift
  "$@" &
  local pid="$!"
  local started_at
  started_at="$(date +%s)"

  while kill -0 "${pid}" >/dev/null 2>&1; do
    sleep "${PROGRESS_POLL_SECONDS}"
    if kill -0 "${pid}" >/dev/null 2>&1; then
      local now
      now="$(date +%s)"
      printf '... %s still running after %ss\n' "${label}" "$((now - started_at))"
    fi
  done

  wait "${pid}"
}

garage_exec() {
  compose exec -T garage /garage -c /etc/garage.toml "$@"
}

bootstrap_garage() {
  local garage_node=""
  local garage_node_id=""
  local access_key_id="${ARC_S3_ACCESS_KEY_ID:-GK000000000000000000000001}"
  local secret_access_key="${ARC_S3_SECRET_ACCESS_KEY:-1111111111111111111111111111111111111111111111111111111111111111}"
  local bucket="${ARC_S3_BUCKET:-riverhog}"

  run_with_progress "garage startup" compose up --detach garage

  for _ in $(seq 1 60); do
    garage_node="$(garage_exec node id 2>/dev/null | tail -n 1 || true)"
    if [[ "${garage_node}" == *@* ]] && garage_exec -h "${garage_node}" status >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done

  if [[ "${garage_node}" != *@* ]]; then
    printf 'garage bootstrap failed: could not resolve the running node id\n' >&2
    exit 1
  fi

  garage_node_id="${garage_node%@*}"
  run_with_progress \
    "garage layout assign" \
    garage_exec -h "${garage_node}" layout assign -z local -c 1GB "${garage_node_id}"
  run_with_progress \
    "garage layout apply" \
    garage_exec -h "${garage_node}" layout apply --version 1
  run_with_progress \
    "garage key import" \
    garage_exec -h "${garage_node}" key import --yes -n "${access_key_id}" "${access_key_id}" "${secret_access_key}"
  run_with_progress \
    "garage bucket create" \
    garage_exec -h "${garage_node}" bucket create "${bucket}"
  run_with_progress \
    "garage bucket allow" \
    garage_exec -h "${garage_node}" bucket allow --read --write --owner "${bucket}" --key "${access_key_id}"
  run_with_progress \
    "garage lifecycle configure" \
    compose run --rm --entrypoint python "${COMPOSE_RUN_TTY_ARGS[@]}" test tests/harness/configure_garage.py
}

if [[ "${REQUIRES_SIDECARS}" == "1" ]]; then
  export ARC_ENABLE_TEST_CONTROL="${ARC_ENABLE_TEST_CONTROL:-1}"
  export UPLOAD_EXPIRY_SWEEP_INTERVAL="${UPLOAD_EXPIRY_SWEEP_INTERVAL:-1s}"
  compose build app
  compose down --volumes --remove-orphans >/dev/null 2>&1 || true
  bootstrap_garage
  run_with_progress "sidecar startup" compose up --detach webdav tusd
  run_with_progress "app startup" compose up --detach --wait app
fi

run_test_container() {
  compose run \
    --rm \
    "${COMPOSE_RUN_TTY_ARGS[@]}" \
    "${COMPOSE_RUN_ENV_ARGS[@]}" \
    test \
    "$@"
}

if [[ "${MODE}" == "canonical" ]]; then
  run_phase() {
    local label="$1"
    shift
    local started_at
    started_at="$(date +%s)"

    printf '\n==> %s\n' "${label}"
    run_with_progress "${label}" "$@"

    local finished_at
    finished_at="$(date +%s)"
    printf '==> %s finished in %ss\n' "${label}" "$((finished_at - started_at))"
  }

  run_phase "acceptance" run_test_container -q -m acceptance tests/acceptance
  run_phase "integration + unit" run_test_container -q tests/integration tests/unit
  exit 0
fi

run_with_progress "pytest" run_test_container "$@"
