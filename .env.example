API_PORT=8080
REDIS_PORT=6379

ARCHIVE_ROOT=/var/lib/archive
REDIS_URL=redis://redis:6379/0
API_BASE_URL=http://localhost:8080
SQLITE_PATH=/var/lib/archive/catalog/catalog.sqlite3
API_TOKEN=change-me
ISO_AUTHORING_COMMAND=xorriso
CONTAINER_WEBHOOK_DISPATCH_INTERVAL_SECONDS=5
CONTAINER_WEBHOOK_TIMEOUT_SECONDS=10
CONTAINER_WEBHOOK_RETRY_SECONDS=60
AGE_CLI=age
AGE_BATCHPASS_PASSPHRASE=change-me
AGE_BATCHPASS_WORK_FACTOR=18
AGE_BATCHPASS_MAX_WORK_FACTOR=30

CONTAINER_TARGET_GB=50
CONTAINER_FILL_GB=45
CONTAINER_SPILL_FILL_GB=35
CONTAINER_BUFFER_MAX_GB=250
