{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riverhog.dev/contracts/operator/action-needed-notification.schema.json",
  "title": "Riverhog Action-Needed Notification Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["event", "title", "body", "urgency", "actions"],
  "properties": {
    "event": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "#/$defs/operatorAction"
      }
    },
    "urgency": {
      "enum": ["attention", "important", "time-sensitive", "approval"]
    },
    "reminder_count": {
      "type": "integer",
      "minimum": 0
    },
    "delivered_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "session_url": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "restore_expires_at": {
      "type": ["string", "null"]
    },
    "affected": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "images": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/image"
      }
    },
    "collection_id": {
      "type": "string",
      "minLength": 1
    },
    "collection_url": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "attempts": {
      "type": "integer",
      "minimum": 1
    },
    "failed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event": {
            "enum": ["images.rebuild_ready", "images.rebuild_ready.reminder"]
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["type", "session_id", "images", "reminder_count"],
        "properties": {
          "type": {
            "const": "image_rebuild"
          },
          "images": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/image"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "const": "collections.glacier_upload.failed"
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["collection_id", "error", "attempts"]
      }
    }
  ],
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["image_id"],
      "properties": {
        "image_id": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "iso_available": {
          "type": "boolean"
        },
        "download_url": {
          "type": "string",
          "minLength": 1
        },
        "image_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operatorAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "command", "argv"],
      "properties": {
        "label": {
          "enum": ["Run arc", "Run arc-disc"]
        },
        "command": {
          "enum": ["arc", "arc-disc"]
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "enum": ["arc", "arc-disc"]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "command": {
                "const": "arc"
              }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "label": {
                "const": "Run arc"
              },
              "argv": {
                "prefixItems": [
                  {
                    "const": "arc"
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "command": {
                "const": "arc-disc"
              }
            },
            "required": ["command"]
          },
          "then": {
            "properties": {
              "label": {
                "const": "Run arc-disc"
              },
              "argv": {
                "prefixItems": [
                  {
                    "const": "arc-disc"
                  }
                ]
              }
            }
          }
        }
      ]
    }
  }
}
