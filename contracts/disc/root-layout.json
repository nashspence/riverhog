{
  "contract": "iso-root-layout/v1",
  "required_root_files": [
    "DISC.yml.age",
    "README.md"
  ],
  "required_root_directories": [
    "collections",
    "files"
  ],
  "plaintext_files": [
    "README.md"
  ],
  "allowed_file_patterns": [
    "^DISC\\.yml\\.age$",
    "^README\\.md$",
    "^collections/[0-9]{6}\\.ots\\.age$",
    "^collections/[0-9]{6}\\.yml\\.age$",
    "^files/[0-9]{6}(?:\\.[0-9]{3})?\\.age$",
    "^files/[0-9]{6}(?:\\.[0-9]{3})?\\.yml\\.age$"
  ]
}
