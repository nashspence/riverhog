{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riverhog.dev/contracts/disc/file-sidecar.schema.json",
  "title": "file-sidecar/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bytes",
    "collection",
    "mode",
    "mtime",
    "path",
    "schema",
    "sha256"
  ],
  "properties": {
    "schema": {
      "const": "file-sidecar/v1"
    },
    "collection": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "pattern": "^/.+$"
    },
    "bytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "mode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "mtime": {
      "type": [
        "integer",
        "null"
      ]
    },
    "uid": {
      "type": "integer"
    },
    "gid": {
      "type": "integer"
    },
    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "index"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "count": {
          "type": "integer",
          "minimum": 2
        }
      }
    }
  }
}
