{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riverhog.dev/contracts/disc/disc-manifest.schema.json",
  "title": "disc-manifest/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "collections",
    "image",
    "schema"
  ],
  "properties": {
    "schema": {
      "const": "disc-manifest/v1"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{8}T[0-9]{6}Z$",
          "minLength": 1
        }
      }
    },
    "collections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/collection"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "absolute_path": {
      "type": "string",
      "pattern": "^/.+$"
    },
    "object_path": {
      "type": "string",
      "pattern": "^files/[0-9]{6}(?:\\.[0-9]{3})?\\.age$"
    },
    "sidecar_path": {
      "type": "string",
      "pattern": "^files/[0-9]{6}(?:\\.[0-9]{3})?\\.yml\\.age$"
    },
    "collection_manifest_path": {
      "type": "string",
      "pattern": "^collections/[0-9]{6}\\.yml\\.age$"
    },
    "collection_proof_path": {
      "type": "string",
      "pattern": "^collections/[0-9]{6}\\.ots\\.age$"
    },
    "present_part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "object",
        "sidecar"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "object": {
          "$ref": "#/$defs/object_path"
        },
        "sidecar": {
          "$ref": "#/$defs/sidecar_path"
        }
      }
    },
    "split_parts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "present"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 2
        },
        "present": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/present_part"
          }
        }
      }
    },
    "unsplit_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes",
        "object",
        "path",
        "sha256",
        "sidecar"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/absolute_path"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "object": {
          "$ref": "#/$defs/object_path"
        },
        "sidecar": {
          "$ref": "#/$defs/sidecar_path"
        }
      }
    },
    "split_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes",
        "parts",
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/absolute_path"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "parts": {
          "$ref": "#/$defs/split_parts"
        }
      }
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "id",
        "manifest",
        "proof"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "$ref": "#/$defs/collection_manifest_path"
        },
        "proof": {
          "$ref": "#/$defs/collection_proof_path"
        },
        "files": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/unsplit_file"
              },
              {
                "$ref": "#/$defs/split_file"
              }
            ]
          }
        }
      }
    }
  }
}
